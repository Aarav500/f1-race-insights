# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# Virtual environments
.venv/
venv/
ENV/
env/

# IDEs and editors
.vscode/
.idea/
*.swp
*.swo
*.swn
.DS_Store

# Data directories (should be mounted as volumes)
data/
models/
reports/

# Heavy model and data files (exclude from all subdirectories)
**/*.parquet
**/*.pkl
**/*.joblib
**/*.pt
**/*.pth
**/*.h5
**/*.onnx

# Web/Node.js (for multi-service projects)
web/node_modules/
web/.next/
web/.DS_Store
node_modules/
.next/

# Git
.git/
.gitignore
.gitattributes

# Testing
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
*.coverage

# Documentation
docs/
*.md
!README.md

# CI/CD
.github/
.gitlab-ci.yml

# Docker
docker-compose.yml
Dockerfile*

# Environment files
.env
.env.*
!.env.example

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp
